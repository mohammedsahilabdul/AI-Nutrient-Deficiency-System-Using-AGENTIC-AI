# API Keys
# Using Groq - Free & Fast! Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Anthropic Claude (requires payment)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Optional: Web search
SERPER_API_KEY=your_serper_api_key_for_web_search

# Model Configuration
USE_GROQ=true
USE_VLLM_LOCAL=false
VLLM_SERVER_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-2-7b-hf

# Database
DATABASE_URL=sqlite:///./medical_db.db

# Environment
DEBUG_MODE=false
