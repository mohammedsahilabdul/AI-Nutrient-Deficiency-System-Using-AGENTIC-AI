# AI Medical Diagnostic System - Configuration Template
# Copy this file and rename to .env, then fill in your API keys

# ========================================
# LLM CONFIGURATION (REQUIRED)
# ========================================

# Option 1: GROQ (FREE - Recommended for testing)
USE_GROQ=true
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# Option 2: Anthropic Claude (Paid - Better quality)
# USE_GROQ=false
# ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# ========================================
# EMAIL CONFIGURATION (REQUIRED for confirmations)
# ========================================

# Gmail SMTP Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address
SENDER_EMAIL=your-email@gmail.com

# Gmail App Password (NOT your regular password!)
# Get from: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your-app-specific-password-here

# ========================================
# HOSPITAL SEARCH (OPTIONAL)
# ========================================

# Serper API key for web search
# Get from: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ========================================
# APPLICATION SETTINGS
# ========================================

# Enable detailed logging
DEBUG_MODE=true

# Database URL (local SQLite by default)
DATABASE_URL=sqlite:///./medical_db.db

# ========================================
# VLLM LOCAL (Optional - for local models)
# ========================================

# Use local vLLM server instead of cloud APIs
USE_VLLM_LOCAL=false
VLLM_SERVER_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-2-7b-hf

# ========================================
# HOW TO GET API KEYS
# ========================================

# 1. GROQ (FREE - Fastest setup)
#    - Visit: https://console.groq.com/keys
#    - Sign up (1 minute)
#    - Generate API key
#    - Copy key starting with "gsk_"
#
# 2. Gmail App Password
#    - Go: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer"
#    - Generate 16-character password
#    - Copy the password (no spaces)
#
# 3. Serper API (Optional - for better hospital search)
#    - Visit: https://serper.dev
#    - Sign up (free tier: 100 queries/month)
#    - Generate API key
#
# 4. Anthropic Claude (Alternative to Groq)
#    - Visit: https://console.anthropic.com
#    - Create account and add payment
#    - Generate API key
#    - Starts with "sk-ant-"

# ========================================
# IMPORTANT NOTES
# ========================================

# ⚠️  NEVER commit this file to GitHub
# ⚠️  Keep API keys secret
# ⚠️  Use different keys for production
# ⚠️  Rotate keys regularly
# ⚠️  Never share .env file with others

# Example .env file (after filling in):
# 
# USE_GROQ=true
# GROQ_API_KEY=gsk_abc123def456ghi789
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=myemail@gmail.com
# SENDER_PASSWORD=abcd efgh ijkl mnop
# DEBUG_MODE=true
